rules_version = '2';

// Inspirata / Krystine Main — Firestore security rules.
//
// Public site pages read events / blog posts / media library / settings.
// Public forms (newsletter, dosha quiz, booking requests) allow create-only from anyone.
// Signed-in members own their own profile, orders, and support conversation.
// All admin operations are gated on the ADMIN allowlist in the auth token.

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'admin@krystinestlaurent.ca',
          'krystine@inspiratanature.com'
        ];
    }
    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ── Public read, admin write ──
    match /events/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /blogPosts/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /mediaLibrary/{id}  { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}      { allow read: if true; allow write: if isAdmin(); }
    match /siteOverrides/{id} { allow read: if true; allow write: if isAdmin(); }

    // ── Newsletter subscribers ──
    // Public form submits a new signup (email-only). Admins manage the CRM.
    // Unauthenticated clients may NOT read the subscriber list. Unsubscribe
    // goes through the `unsubscribeByToken` Cloud Function (Admin SDK) so we
    // don't need any public read access to this collection.
    match /newsletter/{id} {
      allow create: if request.resource.data.keys().hasAll(['email'])
                    && request.resource.data.email is string;
      allow read, update, delete: if isAdmin();
    }

    // ── Newsletter campaigns ──
    // Only admins can create, update, delete. Bodies are readable by anyone
    // because recipients (including non-admin members) open archived emails
    // in their client portal, and the fetch needs read access to the doc.
    // Sensitive info (subscriber addresses) is NOT in this doc.
    match /newsletters/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bookingRequests/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email']);
      allow read, update, delete: if isAdmin();
    }

    // ── Dosha quiz: public create. Members read their own. Admins full. ──
    match /doshaResults/{id} {
      allow create: if request.resource.data.keys().hasAll(['email', 'dominant']);
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ── "Laissez-vous guider" responses: public create (may be anonymous).
    //    Signed-in members read their own; admins read all. ───────────────
    match /guideResponses/{id} {
      allow create: if true;
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ── Member profiles: user owns their own profile. Admins full. ──
    match /members/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();

      // Newsletter inbox pointers — written by the send Cloud Function (which
      // uses the Admin SDK and bypasses rules). The member can read their own
      // inbox and mark messages as read; they cannot create new entries.
      match /inbox/{newsletterId} {
        allow read: if isSelf(uid) || isAdmin();
        allow update: if isSelf(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
        allow create, delete: if isAdmin();
      }
    }

    // ── Client orders: member reads own, admin full. Created at checkout. ──
    match /clientOrders/{id} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Shopify orders (written by Cloud Functions via Admin SDK, which bypasses rules).
    // Readable by admin in the dashboard. No client writes.
    match /shopifyOrders/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Loyalty points ──
    // `memberPoints/{uid}` — one doc per member; client-side transactions in
    // `src/firebase/points.ts` both increment (award) and decrement (redeem)
    // via the owner's auth. Server-side validation (caps, delta checks) will
    // live in Cloud Functions once we upgrade; for now the audit trail in
    // pointsEvents lets Krystine spot anything fishy from the admin panel.
    match /memberPoints/{uid} {
      allow read, write: if isSelf(uid) || isAdmin();
    }

    // `pointsEvents/{dedupKey}` — append-only log. Owner creates their own
    // events; owner + admin can read. Updates / deletes locked to admin so a
    // user can't rewrite history.
    match /pointsEvents/{id} {
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // `rewardRedemptions/{id}` — client creates a pending redemption; admin
    // fulfills / cancels.
    match /rewardRedemptions/{id} {
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ── Support messaging ──
    // Conversation doc keyed by member uid; only the owner and admins can read/write.
    match /conversations/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if isSelf(uid) || isAdmin();

      match /messages/{mid} {
        allow read: if isSelf(uid) || isAdmin();
        allow create: if (isSelf(uid) && request.resource.data.sender == 'client')
                      || (isAdmin() && request.resource.data.sender == 'admin');
        allow update, delete: if isAdmin();
      }
    }
  }
}
